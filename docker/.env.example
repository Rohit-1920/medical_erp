# ─────────────────────────────────────────────────────────────────────────────
# MedERP Docker Environment Variables
# Copy this file: cp docker/.env.example .env
# Fill in YOUR values — never commit .env to git
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB URIs — replace <password> with your Atlas password
USER_MONGODB_URI=mongodb+srv://admin:<password>@cluster0.xxxxx.mongodb.net/users_db?retryWrites=true&w=majority&appName=Cluster0
PRODUCT_MONGODB_URI=mongodb+srv://admin:<password>@cluster0.xxxxx.mongodb.net/products_db?retryWrites=true&w=majority&appName=Cluster0
ORDER_MONGODB_URI=mongodb+srv://admin:<password>@cluster0.xxxxx.mongodb.net/orders_db?retryWrites=true&w=majority&appName=Cluster0

# JWT Secret — generate your own with: openssl rand -hex 32
JWT_SECRET=your-256-bit-hex-secret-here

# JWT expiry (milliseconds)
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# CORS — replace with your EC2 public IP or domain
# Examples:
#   IP only:  http://13.235.61.131
#   Domain:   https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=http://<your-ec2-public-ip>

# Inventory threshold for low-stock alerts
LOW_STOCK_THRESHOLD=10
